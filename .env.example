# --- LLM Classifier Configuration ---
# Provider: "openai" or "huggingface" (default: huggingface — free, no key needed)
LLM_PROVIDER=huggingface

# OpenAI settings (only needed if LLM_PROVIDER=openai)
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini

# HuggingFace settings (optional — free tier works without an API key)
# Get a free token at https://huggingface.co/settings/tokens
HF_API_KEY=

# Custom LLM endpoint (default: HuggingFace Llama 3.1 8B Instruct)
# For OpenAI-compatible local servers (e.g. Ollama, LiteLLM) set:
# LLM_PROVIDER=openai
# LLM_ENDPOINT=http://localhost:11434/v1
# LLM_MODEL=llama3.1
LLM_ENDPOINT=https://api-inference.huggingface.co/models/meta-llama/Meta-Llama-3.1-8B-Instruct
